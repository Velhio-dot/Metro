    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  - speakerName: Controler
    text: "\u041A\u0430\u043A \u0442\u0432\u043E\u0438 \u0434\u0440\u0443\u0437\u044C\u044F?"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  - speakerName: Controler
    text: "\u0412\u0441\u0451 \u0441\u0434\u0435\u043B\u0430\u043B\u0438?"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  - speakerName: Controler
    text: "Nexs \u041B\u041E\u0425"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  - speakerName: Controler
    text: "\u0422\u0418\u041C\u0410 \u041B\u041E\u0425"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  alternativeLines:
  - speakerName: Controler
    text: "\u041F\u0438\u0437\u0434\u0443\u0439 \u0437\u0430 \u043A\u043B\u044E\u0447\u043E\u043C"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
    voiceLine: {fileID: 0}
    textSpeed: 0.05
    eventAfterLine: {fileID: 0}
    giveItemAfterLine: 0
    itemToGive: {fileID: 0}
  - speakerName: Controler
    text: "\u0418 \u043D\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F
      \u0431\u0435\u0437 \u043D\u0435\u0433\u043E"
    speakerPortrait: {fileID: -1803619880, guid: ba3a832c04b9be742adc7f3fb4be8ec6, type: 3}
